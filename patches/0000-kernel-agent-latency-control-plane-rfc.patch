--- a/kernel/sched/cpufreq_schedutil.c
+++ b/kernel/sched/cpufreq_schedutil.c
@@ -8,6 +8,10 @@
 #include <uapi/linux/sched/types.h>
 #include "sched.h"
 
+#ifdef CONFIG_AGENT_LATENCY
+#include <linux/sched/agent_latency.h>
+#include <trace/events/agent_latency.h>
+#endif
+
 #define IOWAIT_BOOST_MIN        (SCHED_CAPACITY_SCALE / 8)
 
@@ -420,6 +424,30 @@ static inline bool sugov_cpu_is_busy(struct sugov_cpu *sg_cpu) { ... }
 }
 
+#ifdef CONFIG_AGENT_LATENCY
+static unsigned long agent_latency_boost_util(struct sugov_cpu *sg_cpu,
+                                              unsigned long util,
+                                              unsigned long max)
+{
+        struct rq *rq = cpu_rq(sg_cpu->cpu);
+        unsigned long before = util;
+        u64 now = ktime_get_ns();
+
+        if (rq_agent_window_active(rq, now)) {
+                util = max(util, (unsigned long)rq->agent_min_util);
+                util = min(util, max);
+
+                if (util != before)
+                        trace_agent_schedutil_boost(sg_cpu->cpu, before, util);
+        }
+
+        return util;
+}
+#else
+static inline unsigned long agent_latency_boost_util(struct sugov_cpu *sg_cpu,
+                                                     unsigned long util,
+                                                     unsigned long max)
+{
+        return util;
+}
+#endif
+
 static void sugov_update_single_freq(struct update_util_data *hook, u64 time,
                                      unsigned int flags)
 {
@@ -450,6 +478,9 @@ static void sugov_update_single_freq(struct update_util_data *hook, u64 time,
         util = sugov_get_util(sg_cpu, boost);
         max = sg_cpu->max;
 
+        /* RFC: preserve frequency during active agent control-loop windows. */
+        util = agent_latency_boost_util(sg_cpu, util, max);
+
         next_f = get_next_freq(sg_policy, util, max);

