+config AGENT_LATENCY
+        bool "Experimental agent latency windows for schedutil/cpuidle"
+        depends on CPU_FREQ_GOV_SCHEDUTIL
+        default n
+        help
+          Enable experimental scheduler metadata for latency-amplified agent
+          control loops. When a task is marked with SCHED_FLAG_AGENT_LATENCY,
