+#ifdef CONFIG_AGENT_LATENCY
+#include <linux/sched/agent_latency.h>
+#include <trace/events/agent_latency.h>
+#endif
+
@@ -200,6 +205,12 @@ int vfs_statx(int dfd, const char __user *filename, int flags,
         int error;
 
+#ifdef CONFIG_AGENT_LATENCY
+        if (task_agent_latency(current))
+                trace_agent_vfs_op_begin("stat", (void *)filename);
+#endif
+
         /* ... */
 
         error = vfs_statx_path(&path, stat, request_mask, query_flags);
 
