diff --git a/tools/testing/selftests/agent_latency/agent_loop.c b/tools/testing/selftests/agent_latency/agent_loop.c
new file mode 100644
--- /dev/null
+++ b/tools/testing/selftests/agent_latency/agent_loop.c
@@ -0,0 +1,98 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Minimal agent-loop latency microbenchmark.
+ *
+ * One producer periodically signals eventfd. The main thread waits in
+ * epoll_wait(), wakes, performs short CPU work, and repeats. This models
+ * "wait for completion -> parse -> next step".
+ */
+#define _GNU_SOURCE
+#include <errno.h>
+#include <linux/sched.h>
+#include <linux/sched/types.h>
+#include <pthread.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/epoll.h>
+#include <sys/eventfd.h>
+#include <sys/syscall.h>
+#include <time.h>
+#include <unistd.h>
+
+#ifndef SCHED_FLAG_AGENT_LATENCY
+#define SCHED_FLAG_AGENT_LATENCY 0x10000000
+#endif
+
+static int efd;
+
+static int mark_agent_control_thread(void)
+{
+        struct sched_attr attr;
+
+        memset(&attr, 0, sizeof(attr));
+        attr.size = sizeof(attr);
+        attr.sched_policy = SCHED_NORMAL;
+        attr.sched_flags = SCHED_FLAG_AGENT_LATENCY;
+        attr.sched_nice = -5;
+
+        return syscall(SYS_sched_setattr, 0, &attr, 0);
+}
+
+static uint64_t nsec_now(void)
+{
+        struct timespec ts;
+
+        clock_gettime(CLOCK_MONOTONIC, &ts);
+        return (uint64_t)ts.tv_sec * 1000000000ULL + ts.tv_nsec;
+}
+
+static void busy_parse_work(void)
+{
+        volatile uint64_t x = 0;
+        int i;
+
+        for (i = 0; i < 20000; i++)
+                x += i;
+}
+
+static void *producer(void *arg)
+{
+        uint64_t one = 1;
+
+        for (;;) {
+                usleep(500);
+                if (write(efd, &one, sizeof(one)) < 0 && errno != EAGAIN)
+                        perror("write");
+        }
+
+        return NULL;
+}
+
+int main(int argc, char **argv)
+{
+        struct epoll_event ev, out;
+        pthread_t t;
+        uint64_t step = 0;
+        int ep;
+
+        if (argc > 1 && !strcmp(argv[1], "--agent-latency")) {
+                if (mark_agent_control_thread())
+                        perror("sched_setattr(SCHED_FLAG_AGENT_LATENCY)");
+        }
+
+        efd = eventfd(0, EFD_NONBLOCK);
+        if (efd < 0) {
+                perror("eventfd");
+                return 1;
+        }
+
+        ep = epoll_create1(0);
+        if (ep < 0) {
+                perror("epoll_create1");
+                return 1;
+        }
+
+        ev.events = EPOLLIN;
+        ev.data.fd = efd;
+        if (epoll_ctl(ep, EPOLL_CTL_ADD, efd, &ev)) {
+                perror("epoll_ctl");
+                return 1;
+        }
+
+        pthread_create(&t, NULL, producer, NULL);
+
+        for (;;) {
+                uint64_t val, t0 = nsec_now(), t1;
+
+                epoll_wait(ep, &out, 1, -1);
+                t1 = nsec_now();
+                read(efd, &val, sizeof(val));
+                busy_parse_work();
+
+                if ((step++ % 1000) == 0)
+                        printf("step=%llu epoll_wait_us=%llu\n",
+                               (unsigned long long)step,
+                               (unsigned long long)((t1 - t0) / 1000));
+        }
+}
+
+/*
+ * RFC Skeleton: Workqueue and Timer Deferred Completion
+ * These chunks demonstrate where agent latency attribution must be extended
+ * into asynchronous execution paths.
+ */
+
+diff --git a/kernel/workqueue.c b/kernel/workqueue.c
+--- a/kernel/workqueue.c
++++ b/kernel/workqueue.c
+@@ -2340,6 +2340,15 @@ static void process_one_work(struct worker *worker, struct work_struct *work)
+ 
+ 	/*
+ 	 * RFC: If this work_struct is servicing an agentic completion
+	 * (e.g., io_uring polling), the kworker should temporarily inherit
+ 	 * the agent's latency constraints to prevent idle exit latency
+	 * during work processing.
+ 	 */
+ 
+ 	worker->current_work = work;
+ 	worker->current_func = work->func;
+
+diff --git a/kernel/time/hrtimer.c b/kernel/time/hrtimer.c
+--- a/kernel/time/hrtimer.c
++++ b/kernel/time/hrtimer.c
+@@ -1500,6 +1500,14 @@ static void __run_hrtimer(struct hrtimer_cpu_base *cpu_base,
+ 
+ 	/*
+ 	 * RFC: When arming a timer for an agentic workload, the timer
+	 * subsystem must restrict the allowable C-state based on proximity.
+	 * The cpuidle governor must refuse sleep states whose exit latency
+	 * exceeds the time remaining until the timer expires.
+ 	 */
+ 
+ 	trace_hrtimer_expire_entry(timer, now);
+ 	restart = fn(timer);
