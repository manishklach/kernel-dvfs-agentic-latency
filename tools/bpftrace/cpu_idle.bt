#!/usr/bin/env bpftrace

/*
 * Log CPU idle-state transitions in a parse-friendly format.
 *
 * Common conventions:
 *   state >= 0  : entering idle state index
 *   state == -1 : exit from idle on many kernels
 *
 * Output format:
 *   IDLE ts_ns=<nsecs> cpu=<cpu> state=<state>
 */

BEGIN
{
  printf("Tracing power:cpu_idle. Press Ctrl-C to stop.\n");
}

tracepoint:power:cpu_idle
{
  printf("IDLE ts_ns=%llu cpu=%d state=%d\n", nsecs, args->cpu_id, args->state);
}
