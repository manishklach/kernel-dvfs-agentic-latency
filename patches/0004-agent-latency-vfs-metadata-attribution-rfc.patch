         return error;
 }
diff --git a/fs/readdir.c b/fs/readdir.c
--- a/fs/readdir.c
+++ b/fs/readdir.c
@@ -21,6 +21,11 @@
 #include <linux/security.h>
 #include <linux/syscalls.h>
 
+#ifdef CONFIG_AGENT_LATENCY
+#include <linux/sched/agent_latency.h>
+#include <trace/events/agent_latency.h>
+#endif
+
@@ -50,6 +55,12 @@ int iterate_dir(struct file *file, struct dir_context *ctx)
         int res = -ENOENT;
 
+#ifdef CONFIG_AGENT_LATENCY
+        if (task_agent_latency(current))
+                trace_agent_vfs_op_begin("readdir", file);
+#endif
+
         /* ... */
 
         res = file->f_op->iterate_shared(file, ctx);
 
+#ifdef CONFIG_AGENT_LATENCY
+        if (task_agent_latency(current))
+                trace_agent_vfs_op_end("readdir", (long)res);
+#endif
+
         return res;
 }
diff --git a/fs/namei.c b/fs/namei.c
--- a/fs/namei.c
+++ b/fs/namei.c
@@ -43,6 +43,11 @@
 #include <linux/bitops.h>
 #include <linux/init_task.h>
 
+#ifdef CONFIG_AGENT_LATENCY
+#include <linux/sched/agent_latency.h>
+#include <trace/events/agent_latency.h>
+#endif
+
@@ -2400,6 +2405,13 @@ static int path_lookupat(struct nameidata *nd, unsigned int flags, struct path *
 {
         int err;
 
+#ifdef CONFIG_AGENT_LATENCY
+        if (task_agent_latency(current))
+                trace_agent_vfs_path_lookup(nd, flags);
+#endif
+
         /* ... */
         return err;
 }
