diff --git a/include/trace/events/agent_latency.h b/include/trace/events/agent_latency.h
new file mode 100644
--- /dev/null
+++ b/include/trace/events/agent_latency.h
@@ -0,0 +1,74 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#undef TRACE_SYSTEM
+#define TRACE_SYSTEM agent_latency
+
+#if !defined(_TRACE_AGENT_LATENCY_H) || defined(TRACE_HEADER_MULTI_READ)
+#define _TRACE_AGENT_LATENCY_H
+
+#include <linux/tracepoint.h>
+
+TRACE_EVENT(agent_window_refresh,
+        TP_PROTO(int cpu, pid_t pid, u64 step_id, u64 active_until_ns,
+                 unsigned int min_util),
+        TP_ARGS(cpu, pid, step_id, active_until_ns, min_util),
+        TP_STRUCT__entry(
+                __field(int, cpu)
+                __field(pid_t, pid)
+                __field(u64, step_id)
+                __field(u64, active_until_ns)
+                __field(unsigned int, min_util)
+        ),
+        TP_fast_assign(
+                __entry->cpu = cpu;
+                __entry->pid = pid;
+                __entry->step_id = step_id;
+                __entry->active_until_ns = active_until_ns;
+                __entry->min_util = min_util;
+        ),
+        TP_printk("cpu=%d pid=%d step=%llu until=%llu min_util=%u",
+                  __entry->cpu, __entry->pid, __entry->step_id,
+                  __entry->active_until_ns, __entry->min_util)
+);
+
+TRACE_EVENT(agent_schedutil_boost,
+        TP_PROTO(int cpu, unsigned long util_before, unsigned long util_after),
+        TP_ARGS(cpu, util_before, util_after),
+        TP_STRUCT__entry(
+                __field(int, cpu)
+                __field(unsigned long, util_before)
+                __field(unsigned long, util_after)
+        ),
+        TP_fast_assign(
+                __entry->cpu = cpu;
+                __entry->util_before = util_before;
+                __entry->util_after = util_after;
+        ),
+        TP_printk("cpu=%d util_before=%lu util_after=%lu",
+                  __entry->cpu, __entry->util_before, __entry->util_after)
+);
+
+TRACE_EVENT(agent_cpuidle_guard,
+        TP_PROTO(int cpu, int original_state, int selected_state, unsigned int limit_us),
+        TP_ARGS(cpu, original_state, selected_state, limit_us),
+        TP_STRUCT__entry(
+                __field(int, cpu)
+                __field(int, original_state)
+                __field(int, selected_state)
+                __field(unsigned int, limit_us)
+        ),
+        TP_fast_assign(
+                __entry->cpu = cpu;
+                __entry->original_state = original_state;
+                __entry->selected_state = selected_state;
+                __entry->limit_us = limit_us;
+        ),
+        TP_printk("cpu=%d original=%d selected=%d limit_us=%u",
+                  __entry->cpu, __entry->original_state,
+                  __entry->selected_state, __entry->limit_us)
+);
+
+#endif
+
+#include <trace/define_trace.h>

