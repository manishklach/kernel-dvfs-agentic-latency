#!/usr/bin/env bpftrace
/*
 * Trace CPU frequency transitions for agent_loop.
 * Demonstrates schedutil ramping behavior.
 */

tracepoint:power:cpu_frequency
{
    if (comm == "agent_loop") {
        printf("[%llu] CPU %d freq changed to %u kHz\n",
               nsecs, args->cpu_id, args->state);
    }
}
