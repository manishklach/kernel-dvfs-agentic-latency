#!/usr/bin/env bpftrace
/*
 * Measure wakeup-to-run latency for agent_loop.
 * Shows scheduler latency amplification.
 */

tracepoint:sched:sched_wakeup
/args->comm == "agent_loop"/
{
    @wake[args->pid] = nsecs;
}

tracepoint:sched:sched_switch
/args->next_comm == "agent_loop" && @wake[args->next_pid]/
{
    $latency = (nsecs - @wake[args->next_pid]) / 1000;
    @latency_us = hist($latency);
    delete(@wake[args->next_pid]);
}
