#!/usr/bin/env bpftrace
/*
 * Correlate MM faults to block I/O.
 * Output format: timestamp,cpu,pid,event,val
 * 
 * CSV Header: timestamp,cpu,pid,event,val
 */

tracepoint:agent_latency:agent_mm_fault_begin
{
    printf("%llu,%d,%d,fault_begin,%lx\n", nsecs, args->cpu, args->pid, args->address);
}

tracepoint:agent_latency:agent_pagecache_event
/!args->hit/
{
    printf("%llu,%d,%d,cache_miss,%lu\n", nsecs, args->cpu, args->pid, args->pgoff);
}

tracepoint:agent_latency:agent_blk_rq_issue
{
    printf("%llu,%d,0,blk_rq_issue,%p\n", nsecs, args->cpu, args->rq);
}

tracepoint:agent_latency:agent_blk_rq_complete
{
    printf("%llu,%d,0,blk_rq_complete,%p\n", nsecs, args->cpu, args->rq);
}

tracepoint:agent_latency:agent_mm_fault_end
{
    printf("%llu,%d,%d,fault_end,%u\n", nsecs, args->cpu, args->pid, args->ret);
}
