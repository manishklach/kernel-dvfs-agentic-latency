#!/usr/bin/env bpftrace
/*
 * Trace cpuidle state transitions for agent_loop.
 * Shows deep C-state avoidance.
 */

tracepoint:power:cpu_idle
{
    // state 4294967295 (-1) means exiting idle
    if (comm == "agent_loop" && args->state != 4294967295) {
        printf("[%llu] CPU %d entering C-state %u\n",
               nsecs, args->cpu_id, args->state);
    }
}
