#!/usr/bin/env bpftrace
/*
 * Trace workqueue deferred latency for agentic workloads.
 * Measures time between work queued and execution start.
 */

tracepoint:agent_latency:agent_workqueue_queue
{
    @queue_time[args->work] = nsecs;
}

tracepoint:agent_latency:agent_workqueue_start
/@queue_time[args->work]/
{
    $latency = (nsecs - @queue_time[args->work]) / 1000;
    @work_latency_us = hist($latency);
    delete(@queue_time[args->work]);
}

tracepoint:agent_latency:agent_workqueue_finish
{
    // Placeholder for execution time constraints
}
