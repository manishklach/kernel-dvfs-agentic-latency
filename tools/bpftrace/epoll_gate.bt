#!/usr/bin/env bpftrace

/*
 * Measure time blocked in epoll_wait() for the selftest process.
 *
 * Output format:
 *   EPOLL ts_ns=<exit_ts> pid=<pid> blocked_us=<us> ret=<ret>
 */

BEGIN
{
  printf("Tracing epoll_wait blocked time for comm=agent_loop. Press Ctrl-C to stop.\n");
}

tracepoint:syscalls:sys_enter_epoll_wait
/comm == "agent_loop"/
{
  @enter_ts[tid] = nsecs;
}

tracepoint:syscalls:sys_exit_epoll_wait
/comm == "agent_loop"/
{
  $start = @enter_ts[tid];

  if ($start) {
    printf("EPOLL ts_ns=%llu pid=%d blocked_us=%llu ret=%d\n",
           nsecs, pid, (nsecs - $start) / 1000, args->ret);
    delete(@enter_ts[tid]);
  }
}
