diff --git a/include/linux/sched/agent_latency.h b/include/linux/sched/agent_latency.h
new file mode 100644
--- /dev/null
+++ b/include/linux/sched/agent_latency.h
@@ -0,0 +1,70 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * Experimental agent-latency helpers.
+ *
+ * Agentic workloads execute short bursts separated by waits on async
+ * completions. This file provides a small scheduler-facing abstraction
+ * for keeping CPU frequency and idle behavior warm across those gaps.
+ */
+#ifndef _LINUX_SCHED_AGENT_LATENCY_H
+#define _LINUX_SCHED_AGENT_LATENCY_H
+
+#include <linux/sched.h>
+#include <linux/ktime.h>
+
+#ifdef CONFIG_AGENT_LATENCY
+
+/* Conservative defaults; production needs cgroup/admin policy. */
+#define AGENT_LATENCY_DEFAULT_WINDOW_NS  (2ULL * NSEC_PER_MSEC)
+#define AGENT_LATENCY_DEFAULT_MIN_UTIL   (SCHED_CAPACITY_SCALE / 2)
+#define AGENT_LATENCY_IDLE_EXIT_LIMIT_US 50
+
+static inline bool task_agent_latency(const struct task_struct *p)
+{
+        return p->sched_flags & SCHED_FLAG_AGENT_LATENCY;
+}
+
+static inline bool rq_agent_window_active(struct rq *rq, u64 now)
+{
+        return rq->agent_active_until_ns > now;
+}
+
+static inline void rq_agent_refresh_window(struct rq *rq,
+                                           unsigned int min_util,
+                                           u64 window_ns)
+{
+        u64 until = ktime_get_ns() + window_ns;
+
+        if (until > rq->agent_active_until_ns)
+                rq->agent_active_until_ns = until;
+
+        if (min_util > rq->agent_min_util)
+                rq->agent_min_util = min_util;
+}
+
+static inline void task_agent_refresh_window(struct rq *rq,
+                                             struct task_struct *p)
+{
+        if (!task_agent_latency(p))
+                return;
+
+        rq_agent_refresh_window(rq,
+                p->agent_min_util ?: AGENT_LATENCY_DEFAULT_MIN_UTIL,
+                p->agent_window_ns ?: AGENT_LATENCY_DEFAULT_WINDOW_NS);
+}
+
+#else
+
+static inline bool task_agent_latency(const struct task_struct *p) { return false; }
+static inline bool rq_agent_window_active(struct rq *rq, u64 now) { return false; }
+static inline void rq_agent_refresh_window(struct rq *rq, unsigned int min_util,
+                                           u64 window_ns) { }
+static inline void task_agent_refresh_window(struct rq *rq,
+                                             struct task_struct *p) { }
+
+#endif
+
+#endif

