#!/usr/bin/env bpftrace
/*
 * Trace workqueue deferred latency.
 * Measures the time between work queued and work executed by a kworker.
 * High latency here adds directly to agent wakeup time.
 */

tracepoint:workqueue:workqueue_queue_work
{
    @queue_time[args->work] = nsecs;
}

tracepoint:workqueue:workqueue_execute_start
/@queue_time[args->work]/
{
    $latency = (nsecs - @queue_time[args->work]) / 1000;
    @work_latency_us = hist($latency);
    delete(@queue_time[args->work]);
}
