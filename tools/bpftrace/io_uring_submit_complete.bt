#!/usr/bin/env bpftrace
/*
 * Measure io_uring submit to complete latency for agent workloads.
 * Output format: timestamp,cpu,pid,step_id,req_id,latency_us
 * 
 * CSV Header: timestamp,cpu,pid,step_id,req_id,latency_us
 */

tracepoint:agent_latency:agent_io_uring_submit
{
    @submit_time[args->user_data] = nsecs;
}

tracepoint:agent_latency:agent_io_uring_complete
/@submit_time[args->user_data]/
{
    $latency = (nsecs - @submit_time[args->user_data]) / 1000;
    printf("%llu,%d,%d,%llu,%u,%llu\n", nsecs, args->cpu, args->pid, args->step_id, args->req_id, $latency);
    delete(@submit_time[args->user_data]);
}

/* Fallback for unpatched kernels:
 * tracepoint:syscalls:sys_enter_io_uring_enter { ... }
 * tracepoint:syscalls:sys_exit_io_uring_enter { ... }
 */
